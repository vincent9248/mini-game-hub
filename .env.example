# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/minigamehub?schema=public"

# NextAuth (用户认证)
AUTH_SECRET="your-nextauth-secret-key-here"
AUTH_URL="http://localhost:3000"

# Admin Authentication (独立的管理员认证系统)
# 请在生产环境中使用强密钥 (至少 32 个字符)
ADMIN_SECRET_KEY="your-secure-admin-secret-key-change-in-production-32chars"

# 默认管理员账户 (初始化时使用，请在首次登录后修改)
ADMIN_DEFAULT_EMAIL="admin@example.com"
ADMIN_DEFAULT_PASSWORD="admin123456"
ADMIN_DEFAULT_NAME="超级管理员"
